# Copy to .env.fly.local and fill in deployment-specific public values.
# This file controls app names, organization, domains, and env file locations.

FLY_ORG=my-fly-org
FLY_REGION=iad
FLY_APP_PREFIX=open-wearables

FLY_API_APP=open-wearables-api
FLY_FRONTEND_APP=open-wearables-frontend
FLY_FLOWER_APP=open-wearables-flower
FLY_REDIS_APP=open-wearables-redis
FLY_SVIX_APP=open-wearables-svix

FLY_API_URL=https://api.example.com
FLY_FRONTEND_URL=https://app.example.com
FLY_CORS_ORIGINS=https://app.example.com

FLY_BACKEND_ENV_FILE=.env.fly.backend.local
FLY_FRONTEND_ENV_FILE=.env.fly.frontend.local
FLY_FLOWER_ENV_FILE=.env.fly.flower.local
FLY_SVIX_ENV_FILE=.env.fly.svix.local
