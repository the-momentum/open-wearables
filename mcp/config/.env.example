# Open Wearables MCP Server Configuration
# Copy this file to .env and fill in your values

# Required: Backend API URL
# For local development with Docker: http://localhost:8000
# For production: https://api.your-domain.com
OPEN_WEARABLES_API_URL=http://localhost:8000

# Required: Your Open Wearables API key
# Get this from the Open Wearables developer portal or admin panel
OPEN_WEARABLES_API_KEY=ow_your_api_key_here

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: HTTP request timeout in seconds
REQUEST_TIMEOUT=30

# --- HTTP Transport (for remote deployment) ---

# Transport protocol: "stdio" (default, for Claude Desktop/Cursor) or "http" (for Railway etc.)
MCP_TRANSPORT=stdio

# Public URL of the MCP server (required for HTTP transport - used for OAuth redirect URIs)
# MCP_BASE_URL=https://your-mcp-server.railway.app

# Host to bind HTTP server to (default: 0.0.0.0)
# MCP_HOST=0.0.0.0

# Port for HTTP server (default: 8080, Railway injects PORT automatically)
# MCP_PORT=8080

# In HTTP mode, users authenticate via OAuth 2.1 flow:
# 1. AI assistant redirects user to the MCP server's /authorize endpoint
# 2. User enters their Open Wearables API key from the developer panel
# 3. Server validates the key and issues an OAuth token
# No extra auth config needed - uses existing API keys from the developer panel.
