#--- APP ---#
ENVIRONMENT="local"  #--- local | test | staging | production
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000"]
# CORS_ALLOW_ALL=false  # Allow any origin instead of the CORS_ORIGINS list
# API_NAME="Open Wearables API"  # FastAPI title
# PAGING_LIMIT=100  # Default page size for list endpoints
# ACCESS_LOG_LEVEL=errors  # all | errors | off. Default: errors in production, all elsewhere
# LOG_ERROR_RESPONSE_BODY=false  # include the 4xx response body the client saw in the access log
# LOG_ERROR_RESPONSE_BODY_MAX_BYTES=8192  # truncate a logged body to this size
# LOG_ERROR_RESPONSE_BODY_MAX_PER_MINUTE=60  # cap logged bodies/min so a client hammering 4xx can't flood logs

#--- AUTH ---#
#--- Generate: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=secret-key-str
# ALGORITHM=HS256                 #--- JWT signing algorithm
# ACCESS_TOKEN_EXPIRE_MINUTES=60  #--- Lifetime of issued access tokens
# MIN_PASSWORD_LENGTH=8

#--- ADMIN SEED ---#
#--- Auto-created on first startup if no developer account exists
ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=your-secure-password

#--- EMAIL (Resend) ---#
RESEND_API_KEY=your-resend-api-key
FRONTEND_URL=http://localhost:3000  #--- Base URL used in email links

#--- DATABASE ---#
DB_HOST=db
DB_PORT=5432
DB_NAME=open-wearables
DB_USER=open-wearables
DB_PASSWORD=open-wearables

#--- REDIS ---#
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_SSL=false  #--- true for TLS (e.g. AWS ElastiCache with transit encryption)
# REDIS_PASSWORD=your-secure-password  #--- Set for production
# REDIS_USERNAME=default               #--- Redis 6.0+ ACL

#--- SENTRY ---#
SENTRY_ENABLED=true
SENTRY_DSN=""
SENTRY_ENV=production
SENTRY_SAMPLES_RATE=0.5
SENTRY_SERVER_NAME=
# GIT_SHA=  #--- Optional: appended to the Sentry release identifier

#--- AWS ---#
AWS_BUCKET_NAME=open-wearables
AWS_ACCESS_KEY_ID=your-access-id
AWS_SECRET_ACCESS_KEY=your-access-key
AWS_REGION=eu-north-1
AWS_SNS_TOPIC_ARN=arn:aws:sns:eu-north-1:123456789012:owear

#--- RAW PAYLOAD S3 STORAGE ---#
#--- Used when raw payload storage is set to "s3" (managed in-app, not here).
RAW_PAYLOAD_S3_BUCKET=s3-bucket-name
RAW_PAYLOAD_S3_ENDPOINT_URL=https://s3-compatible-endpoint.com
RAW_PAYLOAD_S3_PREFIX=optional-prefix-if-used
OPEN_WEARABLES_API_KEY=secret-key-from-openwearables-settings-credentials  #--- For scripts/replay_raw_payloads.py

#--- SLEEP SESSION TRACKING ---#
# REDIS_SLEEP_TTL_SECONDS=86400  #--- TTL for in-progress sleep session state in Redis (24 h)

#--- OUTGOING WEBHOOKS (Svix) ---#
SVIX_SERVER_URL=http://svix-server:8071  #--- Self-hosted Svix server (default matches docker-compose.yml)
# SVIX_JWT_SECRET=  #--- Signing secret; must match docker-compose. Defaults to SECRET_KEY if unset
# SVIX_AUTH_TOKEN=  #--- Bearer token for the Svix API. Auto-generated from SVIX_JWT_SECRET if unset

#--- PROVIDERS ---#
#--- Provider OAuth credentials are configured in-app (provider_settings), not here.
API_BASE_URL=http://localhost:8000  #--- Public base URL of the API (OAuth redirect URIs, etc.)

#--- Google
# GOOGLE_SERVICE_ACCOUNT_FILE=config/health-webhooks-key.json  #--- SA key for webhook subscriber registration; unset = ADC
