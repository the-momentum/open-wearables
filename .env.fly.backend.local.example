# Copy to .env.fly.backend.local. Values here are synced to the API app with:
# bun run deploy secrets
#
# Blank values are skipped, so this file can also be used for partial rotations.

DB_HOST=
DB_PORT=5432
DB_NAME=open-wearables
DB_USER=
DB_PASSWORD=

SECRET_KEY=
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

SVIX_JWT_SECRET=

# Provider credentials. Keep only the providers you use.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_WEBHOOK_VERIFY_TOKEN=

SUUNTO_CLIENT_ID=
SUUNTO_CLIENT_SECRET=
POLAR_CLIENT_ID=
POLAR_CLIENT_SECRET=
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
ULTRAHUMAN_CLIENT_ID=
ULTRAHUMAN_CLIENT_SECRET=

# Optional integrations.
SENTRY_DSN=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=
