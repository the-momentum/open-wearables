#--- APP ---#
ENVIRONMENT="local"
CORS_ORIGINS=["http://localhost:8000", "https://localhost:8000", "http://localhost", "https://localhost"]

#--- DB ---#
# Docker: DB_HOST is overridden to "db" via docker-compose environment; keep localhost for local dev
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agent
DB_USER=open-wearables
DB_PASSWORD=open-wearables

#--- JWT ---#
SECRET_KEY=secret-key-str
ALGORITHM=HS256

#--- CELERY ---#
# Docker: "redis" resolves to the Redis service. For local dev change to "localhost"
CELERY_BROKER_URL="redis://redis:6379/0"
CELERY_RESULT_BACKEND="redis://redis:6379/0"

#--- SENTRY ---#
SENTRY_ENABLED=False
SENTRY_DSN=""
SENTRY_ENV=production
SENTRY_SAMPLES_RATE=0.5

#--- LLM PROVIDER ---#
# Set LLM_PROVIDER to: anthropic (default) | openai | google
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
LLM_MODEL_WORKERS=claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
GOOGLE_API_KEY=your-google-api-key

#--- OW BACKEND INTEGRATION ---#
OW_API_URL=http://app:8000
# Auto-seeded by backend on startup; override in production with a real key
OW_API_KEY=sk-agent-default-key

#--- CONVERSATION LIFECYCLE ---#
SESSION_TIMEOUT_MINUTES=10
CONVERSATION_CLOSE_HOURS=24
HISTORY_SUMMARY_THRESHOLD=20
MAX_TOOL_CALLS=10
