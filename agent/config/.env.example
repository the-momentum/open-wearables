#--- APP ---#
ENVIRONMENT="local"
CORS_ORIGINS=["http://localhost:8000", "https://localhost:8000", "http://localhost", "https://localhost"]
SERVER_HOST="https://new_project_name.dev"

#--- DB ---#
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agent
DB_USER=open-wearables
DB_PASSWORD=open-wearables

#--- JWT ---#
SECRET_KEY=secret-key-str
ALGORITHM=HS256

#--- CELERY ---#
CELERY_BROKER_URL="redis://redis:6379/0"
CELERY_RESULT_BACKEND="redis://redis:6379/0"

#--- SENTRY ---#
SENTRY_ENABLED=True
SENTRY_DSN=""
SENTRY_ENV=production
SENTRY_SAMPLES_RATE=0.5
