# Copy to .env.fly.flower.local. Flower imports backend settings, so include the
# database and app secrets it needs. FLOWER_BASIC_AUTH format is user:password.

DB_HOST=
DB_PORT=5432
DB_NAME=open-wearables
DB_USER=
DB_PASSWORD=

SECRET_KEY=
FLOWER_BASIC_AUTH=admin:replace-with-a-generated-password
